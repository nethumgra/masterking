// ============================================================
// MASTERKING - Firestore Security Rules
// ============================================================
// HOW TO DEPLOY:
//   1. Firebase Console → Firestore → Rules tab
//   2. Paste this content and click "Publish"
// OR via CLI:
//   firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---- Helper functions ----
    function isLoggedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isLoggedIn() && getUserData().isAdmin == true;
    }
    
    function isSeller() {
      return isLoggedIn() && (getUserData().isSeller == true || getUserData().isReseller == true);
    }
    
    function isAffiliate() {
      return isLoggedIn() && getUserData().isAffiliate == true;
    }

    // ============================================================
    // PUBLIC DATA (products, categories, site content)
    // Anyone can read. Only admins can write.
    // ============================================================
    match /artifacts/{appId}/public/data/products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /artifacts/{appId}/public/data/categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /artifacts/{appId}/public/data/siteContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /artifacts/{appId}/public/data/footerLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /artifacts/{appId}/public/data/stories/{storyId} {
      allow read: if true;
      allow write: if isAdmin() || isSeller();
    }

    // ============================================================
    // USER DATA
    // Users can only read/write their OWN data.
    // ============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Users can update their own profile but NOT grant themselves isAdmin
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
                       !('isAdmin' in request.resource.data) &&
                       request.resource.data.isAdmin == resource.data.get('isAdmin', false);
      allow delete: if isAdmin();
    }
    
    // User subcollections (cart, wishlist, addresses, orders)
    match /users/{userId}/{subcollection}/{docId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ============================================================
    // ORDERS
    // Users can create orders for themselves.
    // Only admins can read all orders and update status.
    // ============================================================
    match /orders/{orderId} {
      allow create: if isLoggedIn() && 
                       request.resource.data.userId == request.auth.uid;
      allow read: if isLoggedIn() && (
                    resource.data.userId == request.auth.uid || 
                    isAdmin() || 
                    isSeller()
                  );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // AFFILIATE DATA
    // Affiliates can read their own data. Admins can read all.
    // ============================================================
    match /affiliates/{affiliateId} {
      allow read: if isOwner(affiliateId) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /affiliatePayouts/{payoutId} {
      allow read: if isAdmin() || (isLoggedIn() && resource.data.affiliateId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ============================================================
    // ADMIN-ONLY COLLECTIONS
    // ============================================================
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /siteSettings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
